NEXT_PUBLIC_APP_URL=http://localhost:3000

# Integrasi sistem inventori BARU (Next.js+Supabase) — cek laporan inventori
# sebelum laporan tutup toko. Endpoint publik /reports/check & /reports/branches.
# Default sudah benar; isi hanya bila domain inventori berbeda.
INVENTORY_API_URL=https://inventory.rotibakarngeunah.my.id/api

# Integrasi sistem Kasir/POS (cek "Tutup Kasir/Shift" sebelum laporan Tutup Toko).
# POS_API_URL = URL api.php POS (mis. https://api.rotibakarngeunah.my.id/api/api.php)
# POS_API_KEY = nilai API_SECRET_KEY di point_of_sales/api/config.php (header X-API-Key)
# Kosongkan keduanya untuk menonaktifkan gate Tutup Kasir (gate inventori tetap jalan).
POS_API_URL=
POS_API_KEY=

# Integrasi Purchase Order — endpoint publik GET /api/public/full-shift-dayoff
# (dipanggil server-to-server oleh sistem Purchase Order, header X-API-Key) untuk
# deteksi otomatis outlet Full Shift yang semua stafnya libur pada tanggal tertentu.
# Isi dengan nilai random yang SAMA PERSIS dengan STAFF_PORTAL_API_KEY di server/.env
# purchase_order. Kosongkan untuk menonaktifkan endpoint ini (return 503).
PO_API_KEY=
