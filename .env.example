# Photo Storage Hosting
PHOTO_STORAGE_BASE_URL=https://foto-laporan-area.rotibakarngeunah.my.id
PHOTO_UPLOAD_ENDPOINT=https://foto-laporan-area.rotibakarngeunah.my.id/api/upload-laporan-area.php
# Server-side shared secret for signing photo uploads (HMAC).
# Optional: app ships with a built-in default so attendance/reports work without it.
# To harden, set the SAME random value here AND on the PHP photo hosting; leave blank to use the default.
